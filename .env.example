# Nepal Election Results Platform - Environment Configuration

# Mode: 'demo' for generated sample data, 'live' for real scraping
DATA_MODE=demo

# Scraping interval in seconds (30-60 recommended)
SCRAPE_INTERVAL_SECONDS=45

# Ekantipur scraping target (update if URL structure changes)
EKANTIPUR_RESULTS_URL=https://election.ekantipur.com/results

# Election Commission Nepal
EC_NEPAL_URL=https://result.election.gov.np

# Server port
PORT=3000

# Logging
LOG_LEVEL=info
LOG_RAW_RESPONSES=true

# Rate limiting
MAX_REQUESTS_PER_MINUTE=30
